{
  "name": "vibeshot",
  "version": "0.1.0",
  "description": "Open-source screenshot shelf for AI coding agents on Windows and Linux. Capture, copy, and drag PNGs into prompts and terminals.",
  "main": "src/main.js",
  "desktopName": "vibeshot.desktop",
  "author": "Alan Luckey-Faraday",
  "homepage": "https://github.com/luckeyfaraday/vibe-shot#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/luckeyfaraday/vibe-shot.git"
  },
  "bugs": {
    "url": "https://github.com/luckeyfaraday/vibe-shot/issues"
  },
  "scripts": {
    "dev": "electron .",
    "start": "electron .",
    "check": "node --check src/capture.js && node --check src/main.js && node --check src/preload.js && node --check src/renderer.js && node --test",
    "test": "node --test",
    "dist:appimage": "electron-builder --linux AppImage --publish never",
    "dist:windows": "electron-builder --win nsis --publish never",
    "install:local": "bash scripts/install-local.sh",
    "uninstall:local": "bash scripts/uninstall-local.sh"
  },
  "keywords": [
    "screenshot",
    "screenshot-tool",
    "screenshot-shelf",
    "screen-capture",
    "ai-coding-agents",
    "coding-agents",
    "developer-tools",
    "productivity",
    "electron",
    "windows",
    "linux",
    "appimage",
    "codex",
    "claude-code",
    "opencode"
  ],
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "build": {
    "appId": "dev.luckeyfaraday.vibeshot",
    "productName": "VibeShot",
    "artifactName": "VibeShot-${version}-${arch}.${ext}",
    "asar": true,
    "compression": "normal",
    "files": [
      "src/**/*",
      "!src/capture-windows.ps1",
      "package.json"
    ],
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "Utility",
      "executableName": "vibeshot",
      "syncDesktopName": true,
      "icon": "build/icon.png"
    },
    "appImage": {
      "compression": "zstd"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build/icon.ico",
      "extraResources": [
        {
          "from": "src/capture-windows.ps1",
          "to": "capture-windows.ps1"
        }
      ]
    },
    "nsis": {
      "oneClick": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "VibeShot"
    }
  },
  "devDependencies": {
    "electron": "43.1.0",
    "electron-builder": "26.15.3"
  }
}
